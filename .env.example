# ─────────────────────────────────────────────────────────────────
# AgentOps Control Tower — environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=agentops
POSTGRES_USER=agentops
POSTGRES_PASSWORD=agentops
POSTGRES_PORT=5432

# ── FastAPI ───────────────────────────────────────────────────────
API_PORT=8000
DEBUG=false
# CORS — defaults cover localhost:3000/3001/3002 for Next.js dev.
# Set this explicitly in production: CORS_ORIGINS=["https://your-domain.com"]
# CORS_ORIGINS=["http://localhost:3000"]

# Async connection URL (used by the API at runtime)
DATABASE_URL=postgresql+asyncpg://agentops:agentops@postgres:5432/agentops

# Sync connection URL (used by Alembic for migrations)
DATABASE_URL_SYNC=postgresql+psycopg2://agentops:agentops@postgres:5432/agentops

# ── LLM Provider ─────────────────────────────────────────────────
# Leave blank to use the deterministic mock fallback in the demo RAG app.
# Provider abstraction supports OpenAI-compatible APIs.
# Gemini/Anthropic support planned for v2 (see docs/roadmap.md).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Next.js Frontend ─────────────────────────────────────────────
WEB_PORT=3000
# This is passed to the browser, so must be a public URL, not the Docker service name.
# For local dev without Docker: http://localhost:8000
# For Docker Compose: http://localhost:8000 (exposed port)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Feature flags ─────────────────────────────────────────────────
# Set to true to enable LLM-as-judge evaluation (v2 feature, not yet implemented)
USE_LLM_EVALUATOR=false
